APP_NAME=CinemaClub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

# URL del frontend Vue (necesaria para CORS y redirecciones de email)
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Base de datos ────────────────────────────────────────────────────────────
# El proyecto usa MySQL / TiDB Cloud (no SQLite).
# Para desarrollo local puedes usar MySQL estándar.
# Para TiDB Cloud añade MYSQL_ATTR_SSL_CA (ver abajo).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cinemaclub
DB_USERNAME=root
DB_PASSWORD=

# Solo necesario si usas TiDB Cloud (SSL obligatorio):
# MYSQL_ATTR_SSL_CA=/etc/ssl/cert.pem   # macOS
# MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt  # Linux

# ─── Sesión / Cola ───────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# La cola se procesa con el scheduler (ver routes/console.php).
# En desarrollo: php artisan queue:work
QUEUE_CONNECTION=database

CACHE_STORE=database

# ─── Sanctum (autenticación SPA) ─────────────────────────────────────────────
# Añade aquí los dominios del frontend separados por coma
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:8001

# ─── Cloudinary (almacenamiento de imágenes) ─────────────────────────────────
# Obtén tus credenciales en https://cloudinary.com/console
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=

# ─── OpenAI (procesamiento IA del panel editorial) ───────────────────────────
# Usado por ProcessNewsItemWithAIJob para analizar noticias con GPT-4o-mini
OPENAI_API_KEY=

# ─── TMDB (metadatos de películas) ───────────────────────────────────────────
# Obtén tu API key en https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ─── Azure Translator (traducción automática) ────────────────────────────────
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=francecentral

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Vite (frontend) ─────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=http://localhost:8001
