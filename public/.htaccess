<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Pasar cabeceras de auth a PHP (necesario en algunos hostings compartidos)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Quitar trailing slash si no es directorio
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # 1. Rutas de API y Sanctum → Laravel (index.php)
    RewriteRule ^(api|sanctum)(/.*)?$ index.php [L,QSA]

    # 2. Archivos y directorios que existen → servirlos directamente
    #    (assets JS/CSS, imágenes, sw.js, manifest, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 3. Todo lo demás (rutas de Vue Router) → Vue SPA
    RewriteRule ^ index.html [L]
</IfModule>
