<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On
    RewriteBase /

    # Pasar cabeceras de auth a PHP (necesario en Hostinger shared hosting)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Bloquear acceso directo a la carpeta backend-api/ salvo a través de las reglas de abajo
    RewriteRule ^backend-api/$ - [F,L]

    # 1. Rutas de API y Sanctum → Laravel (backend-api/index.php)
    RewriteRule ^(api|sanctum)(/.*)? backend-api/index.php [L,QSA]

    # 2. Archivos y directorios que existen → servirlos directamente
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 3. Todo lo demás (rutas de Vue Router) → Vue SPA
    RewriteRule ^ index.html [L]
</IfModule>
